{
  "name": "portfolio",
  "private": true,
  "version": "9.5.0",
  "type": "module",
  "homepage": "https://aamirhusain.me",
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "emulators": "firebase emulators:start --import ./emulators_data --export-on-exit",
    "dev": "vite --host",
    "local": "concurrently \"npm run emulators\" \"npm run dev\"",
    "build": "tsc && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "firebase": "^12.4.0",
    "katex": "^0.17.0",
    "lodash": "^4.17.21",
    "lucide-react": "^1.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-katex": "^3.1.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.8.2",
    "react-syntax-highlighter": "^16.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwindcss": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/lodash": "^4.17.17",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-katex": "^3.0.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0"
  }
}
